# === Hunt Configuration ===

# What to hunt (lowercase): charmander, squirtle, bulbasaur, aerodactyl,
# kabuto, omanyte, lapras, pikachu, nidoranm, nidoranf, dratini
TARGET_POKEMON=charmander

# Game cartridge: fire-red or leaf-green
GAME=leaf-green

# Hunt type: starter | wild | static | casino
HUNT_TYPE=starter

# Hunt mode: reset (basic soft-reset) | rng (emulator memory reads) | switch-rng (blind RNG timing)
HUNT_MODE=switch-rng

# === Environment ===

# emulator (mGBA) or switch (real Switch hardware via ESP32)
HUNT_ENV=switch

# === Switch Hardware ===

# ESP32-S3 serial port (ls /dev/cu.usbmodem* to find it)
SWITCH_SERIAL_PORT=/dev/cu.usbmodemXXXXX

# Serial baud rate (default 115200)
SWITCH_BAUD=115200

# Capture card device index (run: ffmpeg -f avfoundation -list_devices true -i "" 2>&1)
CAPTURE_DEVICE=0

# === Emulator (mGBA) ===

# mGBA Lua bridge TCP connection
MGBA_HOST=127.0.0.1
MGBA_PORT=8888

# Save state slot for soft resets
SAVE_STATE_SLOT=1

# Fast-forward during hunt (emulator only)
TURBO_ENABLED=true

# === Static/Fossil Hunt ===

# Party slot of the received Pokemon (1-based). Default: 2
# Slot 1 = your lead Pokemon, Slot 2 = newly received Pokemon
PARTY_SLOT=2

# === RNG Manipulation ===

# Expected PRNG advance count from seed to Pokemon generation
RNG_ADVANCE_COUNT=1150

# Advance window (+/- from expected)
RNG_ADVANCE_WINDOW=100

# BIOS boot timing offset in ms
RNG_BIOS_OFFSET=4500

# Target nature (optional, e.g. adamant, jolly, timid)
TARGET_NATURE=

# === Server ===

# Dashboard + API port
PORT=3002

# === Discord Notifications ===

# Discord webhook URL for shiny alerts and milestones
DISCORD_WEBHOOK_URL=
